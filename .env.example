# Database Configuration (PostgreSQL via Docker)
# Use localhost:5432 for local dev, or db:5432 inside Docker network
DATABASE_URL=postgresql+asyncpg://scribe:scribe@localhost:5432/scribedb

# Google API for Gemini LLM
GOOGLE_API_KEY=

# Set to true to use mock LLM responses (for development)
USE_MOCK_LLM=true

# Multi-tenancy (disabled by default for single-tenant deployment)
MULTI_TENANT_ENABLED=false

# License key (optional, skip validation in development)
LICENSE_KEY=

# CORS origins (comma-separated for production)
CORS_ORIGINS=["http://localhost:3000"]

# Backend URL for frontend
BACKEND_URL=http://localhost:8000
